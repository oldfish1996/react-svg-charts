{
  "name": "@oldfish1996/react-svg-charts",
  "version": "0.1.1",
  "description": "React SVG chart components (line, bar, candle, radar, multi).",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oldfish1996/react-svg-charts.git"
  },
  "homepage": "https://oldfish1996.github.io/react-svg-charts/",
  "bugs": {
    "url": "https://github.com/oldfish1996/react-svg-charts/issues"
  },
  "keywords": [
    "react",
    "svg",
    "chart",
    "charts",
    "data-visualization",
    "storybook",
    "line-chart",
    "bar-chart",
    "candlestick",
    "radar-chart"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.js"
    }
  },
  "unpkg": "./dist/umd/index.umd.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=16.14.0",
    "react-dom": ">=16.14.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^16.14.62",
    "@types/react-dom": "^16.9.25",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "rollup": "^4.35.0",
    "rollup-plugin-dts": "^6.1.1",
    "storybook": "^8.6.18",
    "typescript-eslint": "^8.27.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  },
  "packageManager": "pnpm@9.10.0"
}
